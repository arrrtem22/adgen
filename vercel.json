{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "api/index.py"
    },
    {
      "source": "/health",
      "destination": "api/index.py"
    },
    {
      "source": "/generate/(.*)",
      "destination": "api/index.py"
    },
    {
      "source": "/scrape",
      "destination": "api/index.py"
    },
    {
      "source": "/upload/(.*)",
      "destination": "api/index.py"
    },
    {
      "source": "/metrics/(.*)",
      "destination": "api/index.py"
    },
    {
      "source": "/static/(.*)",
      "destination": "api/index.py"
    }
  ],
  "env": {
    "PYTHONPATH": "."
  }
}
